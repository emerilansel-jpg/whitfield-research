---
const { text } = Astro.props;
---
<div style="background:#FFF8E7;border:1px solid #E2D9CC;border-radius:var(--radius);padding:1rem 1.25rem;margin:2rem 0;">
  <p style="font-weight:700;color:var(--color-primary);margin-bottom:0.25rem;">Disclosure</p>
  <p style="font-size:0.95rem;color:var(--color-text);margin:0;line-height:1.6;">{text}</p>
</div>
