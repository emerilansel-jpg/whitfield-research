<div style="background:var(--color-primary);color:#fff;border-radius:var(--radius);padding:2.5rem;">
  <h2 style="color:#fff;">Research Briefing</h2>
  <p style="opacity:0.8;margin-top:0.5rem;">New reports, methodology notes, and correction updates. No spam. Unsubscribe anytime.</p>
  <form action="https://buttondown.com/api/emails/embed-subscribe/whitfield-research" method="post" target="_blank" style="margin-top:1.5rem;display:flex;gap:0.75rem;flex-wrap:wrap;">
    <input type="email" name="email" placeholder="you@company.com" required style="flex:1;min-width:220px;padding:0.75rem 1rem;border:none;border-radius:var(--radius);font-family:var(--font-body);" />
    <button type="submit" style="background:var(--color-accent);color:#fff;border:none;padding:0.75rem 1.5rem;border-radius:var(--radius);font-weight:600;cursor:pointer;font-family:var(--font-body);">Subscribe</button>
  </form>
  <p style="font-size:0.8rem;opacity:0.6;margin-top:1rem;margin-bottom:0;">We never sell or share your email. <a href="/editorial-policy" style="color:#fff;text-decoration:underline;">Read our privacy approach.</a></p>
</div>
