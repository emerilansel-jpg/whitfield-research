---
const { title, description, category, outputFormat, publishDate, slug, status = 'Live', readingTime, heroImage } = Astro.props;
---
<article style="border:1px solid var(--color-border);border-radius:var(--radius);padding:1.5rem;background:var(--color-surface);display:flex;flex-direction:column;height:100%;overflow:hidden;">
  {heroImage && (
    <div style="margin:-1.5rem -1.5rem 1rem -1.5rem;border-bottom:1px solid var(--color-border);overflow:hidden;border-radius:var(--radius) var(--radius) 0 0;">
      <img src={heroImage} alt={title} style="width:100%;height:160px;object-fit:cover;display:block;" />
    </div>
  )}
  <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:0.75rem;align-items:center;">
    <span style="background:var(--color-primary);color:#fff;font-size:0.65rem;padding:0.2rem 0.5rem;border-radius:4px;text-transform:uppercase;letter-spacing:0.03em;">{outputFormat}</span>
    <span style={`font-size:0.65rem;padding:0.2rem 0.5rem;border-radius:999px;font-weight:700;text-transform:uppercase;${status === 'Live' ? 'background:#DCFCE7;color:#166534;' : status === 'In Review' ? 'background:#FEF3C7;color:#92400E;' : 'background:#E2E8F0;color:#475569;'}`}>{status}</span>
  </div>
  <h3 style="font-size:1.15rem;line-height:1.35;">
    <a href={`/research/${slug}`} style="color:var(--color-primary);text-decoration:none;">{title}</a>
  </h3>
  <p style="color:var(--color-muted);font-size:0.9rem;margin-top:0.5rem;line-height:1.6;flex:1;">{description}</p>
  <p style="color:var(--color-muted);font-size:0.8rem;margin-top:1rem;display:flex;gap:0.75rem;flex-wrap:wrap;">
    <span>{category}</span>
    {readingTime && <span>· {readingTime} min read</span>}
    <span>· {publishDate}</span>
  </p>
</article>
