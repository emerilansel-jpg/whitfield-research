---
const { icon, label } = Astro.props;
---
<span style="display:inline-flex;align-items:center;gap:0.4rem;background:var(--color-surface);border:1px solid var(--color-border);padding:0.4rem 0.75rem;border-radius:999px;font-size:0.8rem;font-weight:600;color:var(--color-text);">
  <span aria-hidden="true">{icon}</span>
  {label}
</span>
