---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Contact Whitfield Research Partners.">
  <div class="container" style="padding-top:4rem;padding-bottom:4rem;max-width:720px;">
    <h1>Contact Us</h1>
    <p style="color:var(--color-muted);margin-top:0.75rem;line-height:1.7;">
      We route every inquiry to the right desk. For corrections and new evidence, please use <a href="/submit-evidence">Submit Evidence</a>.
    </p>

    <div style="margin-top:2.5rem;display:grid;gap:2rem;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));">
      <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius);padding:1.5rem;">
        <h3 style="margin-top:0;">General Enquiries</h3>
        <p style="margin-top:0.5rem;color:var(--color-muted);"><a href="mailto:research@whitfieldresearch.com">research@whitfieldresearch.com</a></p>
      </div>
      <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius);padding:1.5rem;">
        <h3 style="margin-top:0;">Editorial Desk</h3>
        <p style="margin-top:0.5rem;color:var(--color-muted);"><a href="mailto:editorial@whitfieldresearch.com">editorial@whitfieldresearch.com</a></p>
      </div>
      <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius);padding:1.5rem;">
        <h3 style="margin-top:0;">Corrections & Evidence</h3>
        <p style="margin-top:0.5rem;color:var(--color-muted);"><a href="mailto:corrections@whitfieldresearch.com">corrections@whitfieldresearch.com</a></p>
      </div>
      <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius);padding:1.5rem;">
        <h3 style="margin-top:0;">Office</h3>
        <p style="margin-top:0.5rem;color:var(--color-muted);">
          350 Park Avenue, Suite 1400<br/>
          New York, NY 10122<br/>
          United States
        </p>
      </div>
      <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius);padding:1.5rem;">
        <h3 style="margin-top:0;">Phone</h3>
        <p style="margin-top:0.5rem;color:var(--color-muted);">+1 212 555 0198</p>
      </div>
      <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius);padding:1.5rem;">
        <h3 style="margin-top:0;">Corrections</h3>
        <p style="margin-top:0.5rem;color:var(--color-muted);"><a href="/submit-evidence" class="btn" style="padding:0.5rem 1rem;font-size:0.85rem;">Submit Evidence</a></p>
      </div>
    </div>
  </div>
</BaseLayout>
