---
import BaseLayout from '../layouts/BaseLayout.astro';
import TrustBadge from '../components/TrustBadge.astro';
import ResearchProcess from '../components/ResearchProcess.astro';
import EditorialCommitments from '../components/EditorialCommitments.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import MetricsStrip from '../components/MetricsStrip.astro';
import EvidenceClassifier from '../components/EvidenceClassifier.astro';
import BenchmarkScorecard from '../components/BenchmarkScorecard.astro';
import DisciplineCard from '../components/DisciplineCard.astro';
import ReportCard from '../components/ReportCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('research'))
  .filter(p => p.data.status === 'Live')
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Home" description="Whitfield Research Partners publishes independent, evidence-based market analysis. Evidence, not endorsement.">
  <!-- Hero -->
  <section style="background:var(--color-primary);color:#fff;padding:6rem 0 5rem;">
    <div class="container">
      <p style="opacity:0.75;letter-spacing:0.12em;text-transform:uppercase;font-size:0.8rem;margin-bottom:1rem;font-weight:600;">Independent Research · Inspectable Evidence</p>
      <h1 style="color:#fff;font-size:clamp(2.2rem,5vw,3.6rem);max-width:720px;line-height:1.15;">
        Research You Can Trace to Its Source
      </h1>
      <p style="opacity:0.85;font-size:1.15rem;max-width:620px;margin-top:1.75rem;line-height:1.75;">
        Whitfield Research Partners produces independent category benchmarks, market analysis, and methodology primers. Every report discloses its criteria, limitations, and evidence classes.
      </p>
      <div style="margin-top:2.5rem;display:flex;gap:1rem;flex-wrap:wrap;">
        <a href="/insights" class="btn">Read Our Insights</a>
        <a href="/methodology" class="btn btn-outline" style="border-color:rgba(255,255,255,0.5);color:#fff;">Our Methodology</a>
      </div>
      <div style="margin-top:2.5rem;display:flex;gap:0.6rem;flex-wrap:wrap;">
        <TrustBadge icon="✓" label="No pay-to-rank" />
        <TrustBadge icon="📋" label="Published methodology" />
        <TrustBadge icon="👤" label="Named reviewers" />
        <TrustBadge icon="↺" label="Open corrections" />
        <TrustBadge icon="⚠" label="Proof gaps disclosed" />
        <TrustBadge icon="★" label="Evidence over advocacy" />
        <TrustBadge icon="⊘" label="Limitations documented" />
      </div>
    </div>
  </section>

  <!-- Research Problem -->
  <section class="section" style="background:var(--color-surface);">
    <div class="container" style="max-width:800px;">
      <h2>The Research Problem</h2>
      <p style="font-size:1.15rem;line-height:1.85;margin-top:1rem;">
        Most market analysis is produced by the industries it covers, shaped by sponsorship, access journalism, or undisclosed relationships. We publish evidence-based research where every conclusion can be inspected, questioned, and corrected.
      </p>
      <p style="font-size:1.05rem;line-height:1.8;color:var(--color-muted);">
        Our standard is simple: evidence first, endorsement never. If we cannot verify a claim, we label it accordingly.
      </p>
      <EvidenceClassifier />
    </div>
  </section>

  <!-- Metrics -->
  <section class="section">
    <div class="container">
      <h2>Our Standard in Numbers</h2>
      <MetricsStrip />
    </div>
  </section>

  <!-- Research Process -->
  <section class="section" style="background:var(--color-surface);">
    <div class="container">
      <h2>How We Work</h2>
      <ResearchProcess />
    </div>
  </section>

  <!-- Featured Benchmark -->
  <section class="section">
    <div class="container">
      <h2>Featured Benchmark Spotlight</h2>
      <p style="color:var(--color-muted);max-width:600px;margin-top:0.5rem;line-height:1.6;">
        A preview of how we score provider quality across a single category. Criteria are fixed before any vendor is named.
      </p>
      <BenchmarkScorecard
        title="Enterprise AI Enablement — Quality Fit Ranking (Preview)"
        scores={[
          { provider: 'CortexStack', score: 94 },
          { provider: 'MindBridge AI', score: 81 },
          { provider: 'PromptFleet', score: 67 },
        ]}
      />
    </div>
  </section>

  <!-- Disciplines -->
  <section class="section" style="background:var(--color-surface);">
    <div class="container">
      <h2>Research Disciplines</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:1.5rem;margin-top:2rem;">
        <DisciplineCard id="D-01" title="Vendor Proof Analysis" status="Active" description="Verify vendor capability claims against public documentation and third-party evidence." />
        <DisciplineCard id="D-02" title="Market Signal Review" status="Active" description="Map market demand, search signals, and practitioner discussion to find evidence asymmetries." />
        <DisciplineCard id="D-03" title="Trust Signal Benchmarks" status="Active" description="Score trust and accountability signals across providers using consistent criteria." />
        <DisciplineCard id="D-04" title="Proof Framework Development" status="In Review" description="Build reusable proof criteria for emerging categories where standards do not yet exist." />
      </div>
    </div>
  </section>

  <!-- Recent Insights -->
  <section class="section">
    <div class="container">
      <div style="display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:1rem;margin-bottom:2rem;">
        <div>
          <h2>Recent Insights</h2>
          <p style="color:var(--color-muted);max-width:540px;margin-top:0.5rem;">Independent reports, benchmarks, and primers from our research desk.</p>
        </div>
        <a href="/insights" style="font-weight:600;">View all insights →</a>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:2rem;">
        {posts.map(post => (
          <ReportCard
            title={post.data.title}
            description={post.data.description}
            category={post.data.category}
            outputFormat={post.data.outputFormat}
            status={post.data.status}
            publishDate={new Date(post.data.publishDate).toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric' })}
            slug={post.id}
            readingTime={Math.max(1, Math.round(post.body.split(/\s+/).length / 200))}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Editorial Standard -->
  <section class="section" style="background:var(--color-surface);">
    <div class="container">
      <h2>Editorial Commitments</h2>
      <EditorialCommitments />
    </div>
  </section>

  <!-- Newsletter -->
  <section class="section">
    <div class="container">
      <NewsletterSignup />
    </div>
  </section>
</BaseLayout>
