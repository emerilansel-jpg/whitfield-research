---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Press & Citations" description="External citations and media mentions of Whitfield Research Partners.">
  <div class="container" style="padding-top:4rem;padding-bottom:4rem;max-width:820px;">
    <h1>Press & Citations</h1>
    <p style="color:var(--color-muted);margin-top:0.75rem;line-height:1.7;">
      A running ledger of third-party citations, media mentions, and academic references to Whitfield Research Partners publications.
    </p>

    <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius);padding:2rem;margin-top:2rem;">
      <p style="line-height:1.8;margin:0;">
        No third-party citations have been independently verified for inclusion yet. This ledger is updated as recognition is documented.
      </p>
    </div>

    <h2 style="margin-top:3rem;">How to Cite Us</h2>
    <p style="line-height:1.8;margin-top:1rem;">
      You may cite our reports with attribution. Please include the report URL, publication date, author, and reviewer. We also ask that you reference our methodology and limitations when summarizing conclusions.
    </p>
    <div style="background:var(--color-bg);border-left:4px solid var(--color-accent);padding:1rem 1.25rem;margin-top:1.5rem;border-radius:0 var(--radius) var(--radius) 0;">
      <p style="font-family:monospace;font-size:0.9rem;margin:0;color:var(--color-text);line-height:1.6;">
        Whitfield Research Partners, "Report Title" (2026), https://whitfieldresearch.com/research/slug. Reviewed by Dr. [Name].
      </p>
    </div>

    <h2 style="margin-top:3rem;">Press Inquiries</h2>
    <p style="line-height:1.8;margin-top:1rem;">
      For press inquiries, embargo requests, or reviewer introductions, contact <a href="mailto:editorial@whitfieldresearch.com">editorial@whitfieldresearch.com</a>.
    </p>
  </div>
</BaseLayout>
