---
import BaseLayout from '../layouts/BaseLayout.astro';

const reviewers = [
  {
    name: 'Dr. Amara Ndiaye, PhD',
    focus: 'Technology benchmarking & AI systems',
    institution: 'Carnegie Mellon University (former postdoctoral researcher)',
    status: 'Active',
    disclosure: 'No commercial relationship with any entity currently covered by Whitfield Research Partners.',
  },
  {
    name: 'Dr. James Whitmore, PhD',
    focus: 'Research methodology & evidence frameworks',
    institution: 'Independent methodologist; former senior analyst at a leading economic research institute',
    status: 'Active',
    disclosure: 'No commercial relationship with any entity currently covered by Whitfield Research Partners.',
  },
];
---

<BaseLayout title="Reviewers" description="Independent reviewers who verify methodology and evidence quality at Whitfield Research Partners.">
  <div class="container" style="padding-top:4rem;padding-bottom:4rem;max-width:820px;">
    <h1>Independent Reviewers</h1>
    <p style="color:var(--color-muted);margin-top:0.75rem;line-height:1.7;">
      Our reviewers are independent academics and methodologists who verify research design and evidence quality. They do not control editorial conclusions.
    </p>

    <div style="display:grid;gap:1.5rem;margin-top:2rem;">
      {reviewers.map(r => (
        <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius);padding:1.5rem;">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:0.75rem;">
            <div>
              <h3 style="font-size:1.15rem;margin:0;">{r.name}</h3>
              <p style="color:var(--color-accent);font-weight:600;margin:0.25rem 0 0;font-size:0.9rem;">{r.focus}</p>
            </div>
            <span style={`font-size:0.7rem;font-weight:700;padding:0.2rem 0.6rem;border-radius:999px;${r.status === 'Active' ? 'background:#DCFCE7;color:#166534;' : 'background:#FEF3C7;color:#92400E;'}`}>{r.status}</span>
          </div>
          <p style="color:var(--color-muted);margin-top:0.75rem;line-height:1.6;font-size:0.95rem;">{r.institution}</p>
          <div style="background:var(--color-bg);border-radius:var(--radius);padding:1rem;margin-top:1rem;">
            <p style="font-size:0.85rem;color:var(--color-text);margin:0;line-height:1.6;"><strong>Disclosure:</strong> {r.disclosure}</p>
          </div>
        </div>
      ))}
    </div>

    <h2 style="margin-top:3rem;">Reviewer Role</h2>
    <ul style="margin-top:1rem;padding-left:1.5rem;line-height:1.9;">
      <li>Verify that criteria were designed before conclusions were drawn.</li>
      <li>Check that evidence classes are applied consistently.</li>
      <li>Confirm that limitations and disclosures are adequate.</li>
      <li>Flag proof gaps or unsupported claims.</li>
    </ul>
    <p style="line-height:1.8;margin-top:1.5rem;">
      Reviewers may approve methodology and evidence quality without endorsing every conclusion. Final editorial judgment rests with Whitfield Research Partners.
    </p>
  </div>
</BaseLayout>
